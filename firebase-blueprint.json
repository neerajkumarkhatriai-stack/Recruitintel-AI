{
  "entities": {
    "Project": {
      "title": "Recruitment Project",
      "description": "A high-level project container for multiple job roles.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["name", "createdAt", "createdBy"]
    },
    "Job": {
      "title": "Job Profile",
      "description": "A specific position under a project.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "reqId": { "type": "string", "description": "Unique requisition ID" },
        "rawDescription": { "type": "string" },
        "structure": { "type": "object" },
        "projectId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["title", "reqId", "rawDescription", "projectId", "createdAt"]
    },
    "Evaluation": {
      "title": "Candidate Evaluation",
      "description": "Assessment of a candidate linked to a JD.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "location": { "type": "string" },
        "currentCompany": { "type": "string" },
        "score": { "type": "number" },
        "status": { "type": "string", "enum": ["New", "Screening", "Interview", "Offered", "Hired", "Rejected"] },
        "data": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "score", "status", "createdAt"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Project collection"
    },
    "/projects/{projectId}/jobs/{jobId}": {
      "schema": "Job",
      "description": "Sub-collection of jobs"
    },
    "/projects/{projectId}/jobs/{jobId}/evaluations/{evalId}": {
      "schema": "Evaluation",
      "description": "Candidate evaluations"
    }
  }
}
