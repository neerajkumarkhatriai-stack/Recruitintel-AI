rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() { return request.auth != null; }
    function isSuperAdmin() { 
      return isSignedIn() && request.auth.token.email == 'neerajkumarkhatri.ai@gmail.com'; 
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isInOrg(orgId) {
      return isSignedIn() && (isSuperAdmin() || getUserData().orgId == orgId);
    }

    function isOrgAdmin(orgId) {
      return isInOrg(orgId) && (isSuperAdmin() || getUserData().role == 'ORG_ADMIN');
    }

    function isSameDomain(data) {
      let publicDomains = ['gmail.com', 'yahoo.com', 'outlook.com', 'hotmail.com', 'icloud.com'];
      let userEmail = request.auth.token.email;
      let userDomain = userEmail.split('@')[1];
      return isSignedIn() && 
             data.get('creatorDomain', '') == userDomain && 
             !(userDomain in publicDomains);
    }

    function isOwner(data) {
      return isSignedIn() && data.createdBy == request.auth.uid;
    }

    // Validations
    function isValidProject(data) {
      return data.keys().hasAll(['name', 'orgId', 'createdAt', 'createdBy']) &&
             data.name is string && data.name.size() <= 200;
    }

    // Collection Rules
    match /organizations/{orgId} {
      allow read: if isSuperAdmin() || isInOrg(orgId);
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin() || isOrgAdmin(orgId);
      allow delete: if isSuperAdmin();

      match /teams/{teamId} {
        allow read: if isSuperAdmin() || isInOrg(orgId);
        allow write: if isSuperAdmin() || isOrgAdmin(orgId);
      }
    }

    function isValidUserProfile(data) {
      let emailDomain = data.email.split('@')[1];
      let orgDomain = get(/databases/$(database)/documents/organizations/$(data.orgId)).data.domain;
      return !data.keys().hasAll(['role']) || 
             data.role != 'ORG_ADMIN' || 
             emailDomain == orgDomain;
    }

    match /users/{userId} {
      allow read: if isSuperAdmin() || request.auth.uid == userId || isInOrg(resource.data.orgId);
      allow create: if isSignedIn() && isValidUserProfile(request.resource.data);
      allow update: if isSuperAdmin() || request.auth.uid == userId || isOrgAdmin(resource.data.orgId);
    }

    match /auditLogs/{logId} {
      allow read: if isSuperAdmin();
      allow create: if isSignedIn();
    }

    match /projects/{projectId} {
      allow read: if isSuperAdmin() || isInOrg(resource.data.get('orgId', '')) || isSameDomain(resource.data);
      allow create: if isSignedIn() && isValidProject(request.resource.data);
      allow update: if isSuperAdmin() || isOrgAdmin(resource.data.get('orgId', '')) || isOwner(resource.data);
      allow delete: if isSuperAdmin() || isOrgAdmin(resource.data.get('orgId', ''));

      match /jobs/{jobId} {
        allow read: if isSuperAdmin() || isInOrg(get(/databases/$(database)/documents/projects/$(projectId)).data.get('orgId', '')) || isSameDomain(get(/databases/$(database)/documents/projects/$(projectId)).data);
        allow create: if isSignedIn() && isValidJob(request.resource.data);
        allow update: if isSuperAdmin() || isOrgAdmin(get(/databases/$(database)/documents/projects/$(projectId)).data.get('orgId', '')) || isOwner(resource.data);
        allow delete: if isSuperAdmin() || isOrgAdmin(get(/databases/$(database)/documents/projects/$(projectId)).data.get('orgId', ''));

        match /evaluations/{evalId} {
          allow read: if isSuperAdmin() || isInOrg(get(/databases/$(database)/documents/projects/$(projectId)).data.get('orgId', '')) || isSameDomain(get(/databases/$(database)/documents/projects/$(projectId)).data);
          allow create: if isSignedIn() && isValidEvaluation(request.resource.data);
          allow update: if isSuperAdmin() || isOrgAdmin(get(/databases/$(database)/documents/projects/$(projectId)).data.get('orgId', '')) || isOwner(resource.data);
          allow delete: if isSuperAdmin() || isOrgAdmin(get(/databases/$(database)/documents/projects/$(projectId)).data.get('orgId', ''));
        }
      }
    }
  }
}
